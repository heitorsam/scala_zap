generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model categoria {
  id_categoria         Int            @id @default(autoincrement())
  nome                 String         @db.VarChar(150)
  sn_ativo             String         @db.Char(1)
  id_usuario_inclusao  Int
  dh_inclusao          DateTime
  id_usuario_alteracao Int?
  dh_alteracao         DateTime?
  item_votacao         item_votacao[]
  sugestao             sugestao[]
}

model abrangencia {
  id_abrangencia       Int            @id @default(autoincrement())
  nome                 String         @db.VarChar(150)
  sn_ativo             String         @db.Char(1)
  id_usuario_inclusao  Int
  dh_inclusao          DateTime
  id_usuario_alteracao Int?
  dh_alteracao         DateTime?
  item_votacao         item_votacao[]
  sugestao             sugestao[]
}

model pais {
  id_pais              Int            @id @default(autoincrement())
  nome                 String         @db.VarChar(150)
  sn_ativo             String         @db.Char(1)
  id_usuario_inclusao  Int
  dh_inclusao          DateTime
  id_usuario_alteracao Int?
  dh_alteracao         DateTime?
  estado               estado[]
  item_votacao         item_votacao[]
  sugestao             sugestao[]
}

model estado {
  id_estado            Int            @id @default(autoincrement())
  id_pais              Int
  nome                 String         @db.VarChar(150)
  sn_ativo             String         @db.Char(1)
  id_usuario_inclusao  Int
  dh_inclusao          DateTime
  id_usuario_alteracao Int?
  dh_alteracao         DateTime?
  pais                 pais           @relation(fields: [id_pais], references: [id_pais])
  item_votacao         item_votacao[]
  sugestao             sugestao[]
}

model item_votacao {
  id_item_votacao      Int         @id @default(autoincrement())
  id_categoria         Int
  id_abrangencia       Int
  id_pais              Int?
  id_estado            Int?
  nome                 String      @db.VarChar(150)
  descricao            String?     @db.VarChar(150)
  link                 String?     @db.VarChar(150)
  img                  String      @db.Text
  sn_ativo             String      @db.Char(1)
  id_usuario_inclusao  Int
  dh_inclusao          DateTime
  id_usuario_alteracao Int?
  dh_alteracao         DateTime?
  categoria            categoria   @relation(fields: [id_categoria], references: [id_categoria])
  abrangencia          abrangencia @relation(fields: [id_abrangencia], references: [id_abrangencia])
  pais                 pais?       @relation(fields: [id_pais], references: [id_pais])
  estado               estado?     @relation(fields: [id_estado], references: [id_estado])
  voto                 voto[]
}

model voto {
  id_voto             Int          @id @default(autoincrement())
  id_item_votacao     Int
  email               String       @db.VarChar(100)
  ip                  String       @db.VarChar(100)
  user_agent          String       @db.VarChar(200)
  sn_assistiu_anuncio String       @db.Char(1)
  dh_inclusao         DateTime
  item_votacao        item_votacao @relation(fields: [id_item_votacao], references: [id_item_votacao])
}

model usuario {
  id_usuario           Int       @id @default(autoincrement())
  nome                 String    @db.VarChar(150)
  email                String    @unique @db.VarChar(100)
  celular              String    @db.VarChar(20)
  senha                String    @db.VarChar(255)
  sn_admin             String    @db.Char(1)
  sn_ativo             String    @db.Char(1)
  id_usuario_inclusao  Int
  dh_inclusao          DateTime
  id_usuario_alteracao Int?
  dh_alteracao         DateTime?
}

model sugestao {
  id_sugestao          Int         @id @default(autoincrement())
  id_categoria         Int
  id_abrangencia       Int
  id_pais              Int?
  id_estado            Int?
  nome                 String      @db.VarChar(150)
  descricao            String?     @db.VarChar(150)
  link                 String?     @db.VarChar(150)
  img                  String?     @db.Text
  sn_ativo             String      @db.Char(1)
  id_usuario_inclusao  Int
  dh_inclusao          DateTime
  id_usuario_alteracao Int?
  dh_alteracao         DateTime?
  categoria            categoria   @relation(fields: [id_categoria], references: [id_categoria])
  abrangencia          abrangencia @relation(fields: [id_abrangencia], references: [id_abrangencia])
  pais                 pais?       @relation(fields: [id_pais], references: [id_pais])
  estado               estado?     @relation(fields: [id_estado], references: [id_estado])
}

model log_api {
  id_log_endpoint Int      @id @default(autoincrement())
  nome            String   @db.VarChar(200)
  ip              String   @db.VarChar(100)
  user_agent      String   @db.VarChar(200)
  dh_inclusao     DateTime
}
